# Server
PORT=3000
NODE_ENV=development

# Firebase Admin — pick ONE approach:
# 1) Path to service account JSON (local dev)
GOOGLE_APPLICATION_CREDENTIALS=

# 2) Or paste full JSON on one line (common on Render)
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}

# Firebase project (required for Storage bucket default)
FIREBASE_PROJECT_ID=

# Optional explicit bucket (defaults to <project_id>.appspot.com)
FIREBASE_STORAGE_BUCKET=
